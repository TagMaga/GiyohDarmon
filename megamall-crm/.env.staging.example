# ── Megamall CRM — Staging Environment Template ──────────────────────────────
#
# Copy to .env on the staging server and fill in ALL required values.
# Never commit the filled-in .env to version control.
#
# Generate secrets with:
#   openssl rand -hex 64
#
# Variables marked [REQUIRED] have no default and will fail at startup if unset.
# Variables marked [RECOMMENDED] have safe defaults but should be set explicitly.
# Variables marked [OPTIONAL] can be left at defaults for staging.

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=15s
SERVER_SHUTDOWN_TIMEOUT=30s

# [REQUIRED] Must be "release" in staging/production — disables gin debug output.
GIN_MODE=release

# [REQUIRED] Comma-separated list of allowed frontend origins. No trailing slash.
# Replace with your actual staging domain.
CORS_ORIGINS=https://staging.yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# [REQUIRED] Full PostgreSQL DSN. Use sslmode=require for staging/production.
DB_DSN=host=your-db-host port=5432 user=megamall_app password=CHANGE_ME dbname=megamall_crm_staging sslmode=require TimeZone=UTC

# [OPTIONAL] Connection pool — defaults are fine for staging load.
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m
DB_SLOW_QUERY_MS=500

# ── JWT ───────────────────────────────────────────────────────────────────────
# [REQUIRED] Generate two independent secrets. Must be ≥ 32 chars. Never reuse dev secrets.
#   openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_SECRET_GENERATE_WITH_OPENSSL

# [OPTIONAL] TTLs — defaults are fine.
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Redis ─────────────────────────────────────────────────────────────────────
# [OPTIONAL] Redis is currently used only for future rate-limit migration.
# Set to your staging Redis URL if available; defaults to localhost.
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@your-redis-host:6379

# ── Media pipeline (internal/media) ────────────────────────────────────────────
# [OPTIONAL] Master switch — defaults to false, leave off until reviewed.
MEDIA_PIPELINE_ENABLED=false
# [REQUIRED only if MEDIA_PIPELINE_ENABLED=true] openssl rand -hex 32
MEDIA_SIGNING_SECRET=

# ── Docker Compose (infra passwords) ─────────────────────────────────────────
# [REQUIRED if using docker-compose] Used by the postgres and redis containers.
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Seed ──────────────────────────────────────────────────────────────────────
# [REQUIRED] Must be "staging". Enables all demo users + password validation.
SEED_MODE=staging

# [REQUIRED] Password for all non-owner demo users. Must not be "password123".
#   openssl rand -base64 18
SEED_DEFAULT_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# [REQUIRED] Password for the owner account. Must not be "password123".
#   Defaults to SEED_DEFAULT_PASSWORD if not set separately.
SEED_OWNER_PASSWORD=CHANGE_ME_SECURE_OWNER_PASSWORD
