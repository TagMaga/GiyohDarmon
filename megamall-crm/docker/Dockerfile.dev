FROM golang:1.22-alpine

RUN apk add --no-cache git ca-certificates curl

# Install Air for hot reload.
RUN go install github.com/air-verse/air@latest

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

# Source is mounted as a volume in docker-compose.dev.yml.
EXPOSE 8080

CMD ["air", "-c", ".air.toml"]
