# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_SHUTDOWN_TIMEOUT=30s
GIN_MODE=debug   # debug | release
# CORS_ORIGINS — comma-separated allowed origins. Empty = allow all (dev only).
# Production/staging: set explicitly, e.g. https://app.example.com
CORS_ORIGINS=

# ── Database ──────────────────────────────────────────────────────────────────
DB_DSN=host=localhost port=5432 user=megamall password=changeme dbname=megamall_crm sslmode=disable TimeZone=UTC
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m
DB_SLOW_QUERY_MS=200

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-generate-with-openssl-rand-hex-64
JWT_REFRESH_SECRET=change-me-different-secret-generate-with-openssl-rand-hex-64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Postgres password (docker-compose only) ───────────────────────────────────
POSTGRES_PASSWORD=changeme
REDIS_PASSWORD=changeme

# ── Seed ──────────────────────────────────────────────────────────────────────
# SEED_MODE: dev | staging | production  (default: dev)
#   dev         — all demo users, password123 allowed
#   staging     — all demo users, explicit password required
#   production  — owner only, explicit password required
SEED_MODE=dev
# Password for all non-owner demo users (dev default: password123)
SEED_DEFAULT_PASSWORD=
# Password for the owner account (dev default: same as SEED_DEFAULT_PASSWORD)
SEED_OWNER_PASSWORD=
