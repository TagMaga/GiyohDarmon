{
  "expo": {
    "name": "MegaMall Courier",
    "slug": "megamall-courier",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ec4899"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "tj.megamall.courier",
      "infoPlist": {
        "NSCameraUsageDescription": "Для фото подтверждения оплаты",
        "NSPhotoLibraryUsageDescription": "Для загрузки фото квитанций"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ec4899"
      },
      "package": "tj.megamall.courier",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset"
    ],
    "scheme": "megamall-courier",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5f020a78-04d3-47c7-9991-3047d864855c"
      }
    },
    "owner": "mahmadnazaralif"
  }
}
